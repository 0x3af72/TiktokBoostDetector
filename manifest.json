{
  "manifest_version": 3,
  "name": "TikTok Boost Detector",
  "version": "1.0.0",
  "description": "Auto-marks TikTok videos & slideshows as Organic / Mixed / Paid from their engagement shape, on video pages and profile grids.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "TikTok Boost Detector",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["*://*.tiktok.com/*"],
      "js": ["src/classify.js", "src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    }
  ]
}
